      "link": null,
      "locked": false,
      "text": "load_config() returns config object:\n    path: all directories\n    parser_config: parser configurations\n    search_params: configurations from SEARCH_PARAMETERS.json",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "load_config() returns config object:\n    path: all directories\n    parser_config: parser configurations\n    search_params: configurations from SEARCH_PARAMETERS.json",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XDOVZEhZh1zaCK6AQOOWy",
      "type": "text",
      "x": 715.9205961348912,
      "y": 751.7633294579134,
      "width": 516.5198974609375,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
